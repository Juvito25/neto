# Evolution API v2.3.1
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://evolution:8080
AUTHENTICATION_TYPE=apikey
AUTHENTICATION_API_KEY=neto_evolution_key
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://neto:secret@postgres:5432/evolution
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://:redis_secret@redis:6379/1
CACHE_REDIS_PREFIX_KEY=evolution
QRCODE_LIMIT=30
QRCODE_COLOR=#0052CC
LOG_LEVEL=ERROR
LOG_COLOR=true
DEL_INSTANCE=false