# NETO — Environment Variables
# Copy to .env and complete values

APP_NAME=NETO
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=neto
DB_USERNAME=neto
DB_PASSWORD=secret

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database

CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

EVOLUTION_PUBLIC_URL=http://localhost:8080
EVOLUTION_API_KEY=neto_evolution_key

MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
# Fallback opcional solo si falla dolarapi.com (cotización ARS por USD)
DOLAR_BLUE_FALLBACK=

PLAN_STARTER_LIMIT=500
PLAN_PRO_LIMIT=2000
PLAN_BUSINESS_LIMIT=999999

TRIAL_DAYS=14

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hola@neto.app
MAIL_FROM_NAME=NETO

VITE_API_URL=http://localhost/api
VITE_APP_NAME=NETO
